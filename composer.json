{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "james-heinrich/getid3": "^1.9",
        "kalnoy/nestedset": "^6.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0",
        "opcodesio/log-viewer": "^3.23",
        "spatie/laravel-pdf": "^2.4",
        "spatie/laravel-permission": "^6.24"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "knuckleswtf/scribe": "^5.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Modules\\User\\": "Modules/User/app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\User\\Database\\Factories\\": "Modules/User/database/factories/",
            "Modules\\User\\Database\\Seeders\\": "Modules/User/database/seeders/",
            "Modules\\Auth\\": "Modules/Auth/app/",
            "Modules\\Auth\\Database\\Factories\\": "Modules/Auth/database/factories/",
            "Modules\\Auth\\Database\\Seeders\\": "Modules/Auth/database/seeders/",
            "Modules\\Users\\": "Modules/Users/app/",
            "Modules\\Users\\Database\\Factories\\": "Modules/Users/database/factories/",
            "Modules\\Users\\Database\\Seeders\\": "Modules/Users/database/seeders/",
            "Modules\\Students\\": "Modules/Students/app/",
            "Modules\\Students\\Database\\Factories\\": "Modules/Students/database/factories/",
            "Modules\\Students\\Database\\Seeders\\": "Modules/Students/database/seeders/",
            "Modules\\Categories\\": "Modules/Categories/app/",
            "Modules\\Categories\\Database\\Factories\\": "Modules/Categories/database/factories/",
            "Modules\\Categories\\Database\\Seeders\\": "Modules/Categories/database/seeders/",
            "Modules\\Teachers\\": "Modules/Teachers/app/",
            "Modules\\Teachers\\Database\\Factories\\": "Modules/Teachers/database/factories/",
            "Modules\\Teachers\\Database\\Seeders\\": "Modules/Teachers/database/seeders/",
            "Modules\\Course\\": "Modules/Course/app/",
            "Modules\\Course\\Database\\Factories\\": "Modules/Course/database/factories/",
            "Modules\\Course\\Database\\Seeders\\": "Modules/Course/database/seeders/",
            "Modules\\Upload\\": "Modules/Upload/app/",
            "Modules\\Upload\\Database\\Factories\\": "Modules/Upload/database/factories/",
            "Modules\\Upload\\Database\\Seeders\\": "Modules/Upload/database/seeders/",
            "Modules\\Lessons\\": "Modules/Lessons/app/",
            "Modules\\Lessons\\Database\\Factories\\": "Modules/Lessons/database/factories/",
            "Modules\\Lessons\\Database\\Seeders\\": "Modules/Lessons/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
